# ─── Core ──────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── Gradio UI (app.py) ────────────────────────────────────────────
PORT=7860
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SHARE=false
GRADIO_SHOW_ERROR=true

# ─── FastAPI (api.py) ──────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0
DEV=false

# ─── Dataset Generator (scripts/generate_golden_dataset.py) ────────
GENERATOR_BACKEND=inference          # "inference" (HF API) | "vllm" (local GPU)
GENERATOR_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16       # HF Inference API model
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8            # vLLM model (FP8 quantized)
VLLM_GPU_MEMORY_UTILIZATION=0.9     # vLLM GPU memory fraction
VLLM_MAX_MODEL_LEN=4096             # vLLM max context length
VLLM_TENSOR_PARALLEL_SIZE=1         # vLLM tensor parallel GPUs
DATASET_REPO=build-small-hackathon/agent-eval-golden-dataset
OUTPUT_FILE=dataset/golden_dataset.jsonl

# ─── LLM Judge (src/llm_judge.py) ──────────────────────────────────
LLM_JUDGE_MODEL=Qwen/Qwen3.6-27B
LLM_JUDGE_TIMEOUT=90