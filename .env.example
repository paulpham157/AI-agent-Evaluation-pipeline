# ─── Core ──────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── Gradio UI (app.py) ────────────────────────────────────────────
PORT=7860
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SHARE=false
GRADIO_SHOW_ERROR=true

# ─── FastAPI (api.py) ──────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0
DEV=false

# ─── Dataset Generator (scripts/generate_golden_dataset.py) ────────
# Uses llama.cpp (no other backends)
LLAMA_MODEL_REPO=nvidia/NVIDIA-Nemotron-3-Nano-4B-GGUF
LLAMA_MODEL_FILE=NVIDIA-Nemotron3-Nano-4B-Q4_K_M.gguf
LLAMA_N_CTX=16384
LLAMA_N_GPU_LAYERS=-1
LLAMA_N_BATCH=512

DATASET_REPO=build-small-hackathon/agent-eval-golden-dataset
OUTPUT_FILE=dataset/golden_dataset.jsonl

# ─── LLM Judge (src/llm_judge.py) ──────────────────────────────────
LLM_JUDGE_MODEL=Qwen/Qwen3.6-27B       # Inference API model ID
LLM_JUDGE_TIMEOUT=90                    # Inference API timeout

# Local judge (llama.cpp GGUF) — auto-downloads Qwen2.5-7B if left empty
LOCAL_JUDGE_MODEL_PATH=                 # path to GGUF file, or leave empty for auto-download
LOCAL_JUDGE_MODEL_FILE=                 # GGUF filename within HF repo (auto-download)
LOCAL_JUDGE_N_CTX=8192                  # context length
LOCAL_JUDGE_N_GPU_LAYERS=-1             # GPU layers (-1 = all)